public class Docente {
private int dni;
//Constructor
public Docente (int dni){
this.dni = dni;
}
/**
* si el argumento dni es valido, setea el valor y retorna true
* Si el valor es invalido, ignora el valor y retorna false
* @param dni. El dni valido debe ser un numero entre 1 y 99999999
*/
public boolean setDni(int dni){
if(dni >= 1 && dni <= 99999999){
this.dni = dni;
return true;
}
else{
return false;
}
}

/**
* Retorna el valor de dni
*/
public int getDni (){
return dni;
}
}

