/* Si el argumento base es valioso, setea el valor y retorna true. 
* Si el valor es invalido, ignora el valor y retorna false.
*@param base. La base valida debe ser un numero entre 0 y 500. 
*/

public boolean setBase (int base){
if (base < 0 || base > 500){
return false; 
}
else {
this.base = base; 
return true; 
}
}

//Retorna el valor del radio 
public int getBase (){
return base;
}

