Para la clase especificada, implementar public HashSet<Persona> listaVotantes ()
Nota: Asuma que la clase Persona implementa los métodos: public int getEdad () y public int getDni ()
import java.util.ArrayList;
import java.util.HashMap;
import java.util.HashSet;
import java.util.List;
import java.util.Iterator;

public class Evaluacion {
    public ArrayList<Persona> personas;
    //Constructor
    public Evaluacion () {
        personas = new ArrayList<Persona>();
    }
    /**
    * Devuelve un HashSet con todas las personas mayores o iguales a 18 anios.
    */
    public HashSet<Persona> listaVotantes (){
        HashSet<Persona> votantes = new HashSet<Persona>();
        for (Persona p : personas) {
            if (p.getEdad() >= 18) {
                votantes.add(p);
            }
        }
        return votantes;
    }
}

