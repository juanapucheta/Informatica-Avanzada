public class Evaluacion {
    public HashMap<String,Bicicleta> clientes;
    
    public Evaluacion () {
        clientes = new HashMap<String,Bicicleta>();
    }
    /**
    * Recorre la coleccion clientes y llama al metodo parchar de la bicicleta
    * asociada al cliente del argumento.
    * @param El cliente a buscar
    */
    public void parcharUna (String cliente) {
        if (clientes.containsKey(cliente)) {
            Bicicleta b = clientes.get(cliente);
            b.parchar();
        }
    }
}


