// Para la clase especificada, implementar public HashSet<Persona> aptosParaVacunacion (
//  Asuma que la clase Persona implementa los métodos: public int getEdad (), public int getDni ()
// 15 / 15
public class Evaluacion {
  public ArrayList<Persona> personas;
  //Constructor
  public Evaluacion () {
    personas = new ArrayList<Persona>();
  }
/**
* Devuelve un HashSet con todas las personas mayores o iguales a 50 anios
* y menores de 70 anios.
*/
  public HashSet<Persona> aptosParaVacunacion ( ){
  HashSet<Persona> aptos= new HashSet<Persona>();
  for(Persona p : personas){
    if(p.getEdad()>= 50 && p.getEdad()<70){
      aptos.add(p);
    }
  }
  return aptos;
  }
}

